# Local dev: keep secrets in .env.dev / .env.prod (gitignored).
# Docker: docker compose up --build reads .env.dev by default (see docker-compose.yml).
# Go run: ./scripts/use-env.sh dev  → symlink .env -> .env.dev, then go run ./cmd/slack-orchestrator

# Slack Socket Mode (orchestrator app)
# Bot token (xoxb-)
SLACK_BOT_TOKEN=
# App-level token for Socket Mode (xapp-)
SLACK_APP_TOKEN=
# Optional: when sharing one .env.dev with employee-factory workers (JOANNE_/ROSS_ Slack tokens), set these
# for the BimRoss orchestrator app instead of overloading SLACK_BOT_TOKEN / SLACK_APP_TOKEN.
# ORCHESTRATOR_SLACK_BOT_TOKEN=
# ORCHESTRATOR_SLACK_APP_TOKEN=

# Squad: either explicit alex=Uxxx,tim=Uyyy,... or comma-separated Slack user IDs in default order
# (alex, tim, ross, garth, joanne) — same idea as employee-factory. Shuffle seed is derived from the map.
MULTIAGENT_BOT_USER_IDS=

# Same Slack user id as the orchestrator bot (users.info / Apps). This process does not read it; set it in
# employee-factory .env.dev too as ORCHESTRATOR_BOT_USER_ID so Joanne create-company can invite this bot to new channels.
# ORCHESTRATOR_BOT_USER_ID=

# Optional: override shuffle/plain-message seed (advanced). If unset, derived from MULTIAGENT_BOT_USER_IDS.
# MULTIAGENT_SHUFFLE_SECRET=

# Optional: comma-separated keys to pin order (overrides shuffle). Leave unset for normal operation.
# MULTIAGENT_ORDER=

# @everyone/@here and @channel use first N in the resolved roster (limits below)
EVERYONE_AGENT_LIMIT=3
CHANNEL_AGENT_LIMIT=3

HTTP_ADDR=:8080
# Logs are always JSON to stdout (internal/logging).
# Enable verbose slack-go socketmode frame logging (debug only).
# SOCKET_MODE_DEBUG=false
# Optional ping timeout override in seconds; 0 uses slack-go default (30s).
# SOCKET_MODE_PING_INTERVAL_SEC=0
# Async Events API worker pool sizing (defaults shown). Keep queue >= workers.
# ORCHESTRATOR_EVENTS_API_WORKERS=8
# ORCHESTRATOR_EVENTS_API_QUEUE_SIZE=256

# Debug: in-memory decision log + GET /debug/decisions (anonymous allowed by default)
# ORCHESTRATOR_DEBUG_TOKEN=            # optional Bearer; if set, clients may send Authorization (or leave anon on)
# ORCHESTRATOR_DEBUG_ALLOW_ANON=true   # default true; set false to require Bearer matching ORCHESTRATOR_DEBUG_TOKEN
# ORCHESTRATOR_DECISION_LOG_MAX=500

# --- JetStream dispatch to employee-factory workers ---
# Prod / k8s: point at the cluster NATS Service (same logical broker worker NATS_URL uses).
# Local split stack: run employee-factory `docker compose --profile local` first, then orchestrator.
#   Docker (this repo, profile local): docker-compose.yml sets ORCHESTRATOR_NATS_URL to
#   nats://host.docker.internal:${NATS_PORT:-4222} — do not duplicate in .env.dev unless you override.
#   Go run on host: ORCHESTRATOR_NATS_URL=nats://127.0.0.1:4222 ORCHESTRATOR_DISPATCH_ENABLED=true
# ORCHESTRATOR_DISPATCH_ENABLED=true
# ORCHESTRATOR_NATS_URL=nats://nats.nats.svc.cluster.local:4222
# ORCHESTRATOR_NATS_STREAM=SLACK_WORK
# Optional JetStream publish hardening (defaults shown): transient NATS errors get exponential backoff (cap 2s) before giving up.
# ORCHESTRATOR_DISPATCH_PUBLISH_MAX_ATTEMPTS=3   # 1–10; 1 disables retries
# ORCHESTRATOR_DISPATCH_PUBLISH_RETRY_BASE_MS=50 # base backoff in ms before first retry (0 = no sleep; for tests only)
#
# Optional: same Redis as employee-factory REDIS_URL / makeacompany user profiles. When set, humans must have
# confirmed Joanne #humans terms (humans_terms_accepted_at) before message / app_mention routing and NATS dispatch.
# ORCHESTRATOR_TERMS_REDIS_URL=redis://127.0.0.1:6379/0
#
# OpenRouter: this process does not call the LLM; JetStream workers (employee-factory) do. Keep ORCHESTRATOR_OR_KEY in the
# same file as workers when you share one .env — workers read it for fallback primary key and cross-cutting LLM paths.
# ORCHESTRATOR_OR_KEY=
