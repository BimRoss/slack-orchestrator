# Slack Socket Mode (orchestrator app)
# Bot token (xoxb-)
SLACK_BOT_TOKEN=
# App-level token for Socket Mode (xapp-)
SLACK_APP_TOKEN=

# Comma-separated employee keys (order matters for @everyone / @channel limits)
MULTIAGENT_ORDER=alex,tim,ross,garth,joanne

# Map Slack bot user IDs to employee keys: alex=Uxxx,tim=Uyyy,...
MULTIAGENT_BOT_USER_IDS=

# Deterministic shuffle for plain-message single responder
MULTIAGENT_SHUFFLE_SECRET=

# @everyone uses first N in MULTIAGENT_ORDER
EVERYONE_AGENT_LIMIT=5
# @channel uses first N
CHANNEL_AGENT_LIMIT=3

HTTP_ADDR=:8080
# Set to true for one JSON log line per routing decision
LOG_JSON=false
