# Slack Socket Mode (orchestrator app)
# Bot token (xoxb-)
SLACK_BOT_TOKEN=
# App-level token for Socket Mode (xapp-)
SLACK_APP_TOKEN=

# Map Slack bot user IDs to employee keys: alex=Uxxx,tim=Uyyy,...
# Roster order is derived from these keys, sorted, then shuffled; seed is derived from the map (no separate shuffle env).
MULTIAGENT_BOT_USER_IDS=

# Optional: override shuffle/plain-message seed (advanced). If unset, derived from MULTIAGENT_BOT_USER_IDS.
# MULTIAGENT_SHUFFLE_SECRET=

# Optional: comma-separated keys to pin order (overrides shuffle). Leave unset for normal operation.
# MULTIAGENT_ORDER=

# @everyone uses first N in the resolved roster; @channel uses first N (limits below)
EVERYONE_AGENT_LIMIT=5
CHANNEL_AGENT_LIMIT=3

HTTP_ADDR=:8080
# Set to true for one JSON log line per routing decision
LOG_JSON=false
