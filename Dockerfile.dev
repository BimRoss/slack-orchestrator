# Local dev: bind-mount repo at /src. Each container start runs `go build` then starts the binary.
# Pick up code changes with `docker compose restart slack-orchestrator` or `docker compose up --build`.
FROM golang:1.23-alpine
WORKDIR /src

RUN apk add --no-cache git ca-certificates

ENV CGO_ENABLED=0
CMD ["sh", "-c", "go build -o /tmp/slack-orchestrator ./cmd/slack-orchestrator && exec /tmp/slack-orchestrator"]
